COMMENT ON TABLE WF_FLOW_DEF IS '审批流定义表，按动态页面 PAGE_CODE 配置审批流';
COMMENT ON COLUMN WF_FLOW_DEF.PAGE_CODE IS '页面编码，对应 T_COST_RESOURCE.PAGE_CODE / 页面元数据 pageCode';
